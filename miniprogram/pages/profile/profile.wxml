<view class="container">
  <!-- 头像昵称 -->
  <view class="profile-header">
    <view class="avatar">☯</view>
    <text class="nickname">专属黄历用户</text>
  </view>

  <!-- 生辰信息 -->
  <view class="card mt-md">
    <view class="card-title">生辰信息</view>
    <view class="info-row">
      <text class="info-label">性别</text>
      <text class="info-val">{{user.gender || '未填写'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">生日</text>
      <text class="info-val">{{user.birthSolar || user.birthLunar || '未填写'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">时辰</text>
      <text class="info-val">{{user.birthTime ? user.birthTime + '时' : '未知'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">出生地</text>
      <text class="info-val">{{user.birthplace || '未填写'}}</text>
    </view>
    <view class="edit-btn mt-md" bindtap="goToBazi">
      <text>{{user.birthSolar || user.birthLunar ? '修改信息' : '填写生辰'}}</text>
    </view>
  </view>

  <!-- 八字摘要 -->
  <view class="card mt-md" wx:if="{{bazi}}">
    <view class="card-title">八字命盘</view>
    <view class="bazi-summary">
      <text class="bazi-text">
        {{bazi.yearPillar.stem}}{{bazi.yearPillar.branch}}
        {{bazi.monthPillar.stem}}{{bazi.monthPillar.branch}}
        {{bazi.dayPillar.stem}}{{bazi.dayPillar.branch}}
        {{bazi.hourPillar ? bazi.hourPillar.stem + bazi.hourPillar.branch : '??'}}
      </text>
      <text class="bazi-sub">日主{{bazi.dayMaster}} · {{bazi.strength ? bazi.strength.strength : ''}}</text>
    </view>
    <view class="edit-btn mt-md" bindtap="goToFortune">
      <text>查看完整命盘</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card mt-md">
    <view class="card-title">关于</view>
    <view class="about-text">
      <text>专属黄历基于中国传统四柱八字命理学，参照《穷通宝典》《三命通会》《滴天髓》《渊海子平》《子平真诠》等经典典籍，为您提供个性化的每日运势参考。</text>
      <text class="disclaimer mt-md">命理分析仅供文化研究参考，不构成决策依据。人生在于自身的努力和选择。</text>
    </view>
  </view>
</view>
