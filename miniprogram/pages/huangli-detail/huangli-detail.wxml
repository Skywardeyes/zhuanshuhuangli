<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载黄历中...</text>
  </view>

  <block wx:if="{{!loading && huangli}}">
    <!-- 运势大分 -->
    <view class="hero">
      <view class="hero-left">
        <text class="hero-lunar">{{huangli.lunarMonthName || ''}}{{huangli.lunarDayName || ''}}</text>
        <text class="hero-solar">{{huangli.date}}</text>
        <text class="hero-ganzhi">{{huangli.dayStem}}{{huangli.dayBranch}}日</text>
      </view>
      <fortune-indicator score="{{huangli.fortuneScore}}" level="{{huangli.fortuneLevel}}" size="large" />
    </view>

    <!-- 完整宜忌 -->
    <view class="card">
      <view class="card-title yi-title">宜</view>
      <view class="tags-wrap">
        <text class="tag tag-green" wx:for="{{huangli.yi}}" wx:key="*this">{{item}}</text>
        <text wx:if="{{huangli.yi.length === 0}}" class="text-gray">无特别宜事</text>
      </view>

      <view class="card-title ji-title mt-md">忌</view>
      <view class="tags-wrap">
        <text class="tag tag-red" wx:for="{{huangli.ji}}" wx:key="*this">{{item}}</text>
        <text wx:if="{{huangli.ji.length === 0}}" class="text-gray">无特别忌事</text>
      </view>
    </view>

    <!-- 与八字的关系 -->
    <view class="card mt-md" wx:if="{{huangli.clash && huangli.clash.descriptions}}">
      <view class="card-title">与您八字的关系</view>
      <view wx:for="{{huangli.clash.descriptions}}" wx:key="*this">
        <text class="clash-desc">{{item}}</text>
      </view>
    </view>

    <!-- 五行运势 -->
    <view class="card mt-md" wx:if="{{huangli.wuxingFortune}}">
      <view class="card-title">五行运势</view>
      <text class="wx-desc">今日五行：{{huangli.wuxingFortune.wuxing || ''}}</text>
      <text class="wx-tip mt-sm">{{huangli.wuxingFortune.description || ''}}</text>
    </view>

    <!-- 其他信息 -->
    <view class="card mt-md">
      <view class="info-row">
        <text class="info-label">冲煞</text>
        <text class="info-val">{{huangli.chongsha || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">吉神方位</text>
        <text class="info-val">{{huangli.luckyDirection ? huangli.luckyDirection.join('、') : '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">胎神</text>
        <text class="info-val">{{huangli.taishen || '-'}}</text>
      </view>
    </view>

    <view class="disclaimer mt-md">
      <text>命理分析仅供参考，人生在于自身的努力和选择。</text>
    </view>
  </block>
</view>
