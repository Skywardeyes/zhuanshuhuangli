<view class="container" style="background: {{currentTheme.bg}}; min-height: 100vh;">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text" style="color: {{currentTheme.subText}};">加载黄历中...</text>
  </view>

  <block wx:if="{{!loading && huangli}}">
    <!-- 运势大分 -->
    <view class="hero" style="border-color: {{currentTheme.border}}; background: {{currentTheme.heroGradient}};">
      <view class="hero-left">
        <text class="hero-lunar" style="color: {{currentTheme.primary}};">{{huangli.lunarMonthName || ''}}{{huangli.lunarDayName || ''}}</text>
        <text class="hero-solar" style="color: {{currentTheme.subText}};">{{huangli.date}}</text>
        <text class="hero-ganzhi" style="color: {{currentTheme.accent}};">{{huangli.dayStem}}{{huangli.dayBranch}}日</text>
      </view>
      <fortune-indicator score="{{huangli.fortuneScore}}" level="{{huangli.fortuneLevel}}" size="large" currentTheme="{{currentTheme}}" />
    </view>

    <!-- 完整宜忌 -->
    <view class="card" style="border-color: {{currentTheme.border}};">
      <view class="card-title yi-title" style="color: {{currentTheme.yiColor}};">宜</view>
      <view class="tags-wrap">
        <text class="tag tag-green" style="background: {{currentTheme.tagBg}}; color: {{currentTheme.yiColor}};" wx:for="{{huangli.yi}}" wx:key="*this">{{item}}</text>
        <text wx:if="{{huangli.yi.length === 0}}" class="text-gray" style="color: {{currentTheme.mutedText}};">无特别宜事</text>
      </view>

      <view class="card-title ji-title mt-md" style="color: {{currentTheme.jiColor}};">忌</view>
      <view class="tags-wrap">
        <text class="tag tag-red" style="background: {{currentTheme.highlight}}; color: {{currentTheme.jiColor}};" wx:for="{{huangli.ji}}" wx:key="*this">{{item}}</text>
        <text wx:if="{{huangli.ji.length === 0}}" class="text-gray" style="color: {{currentTheme.mutedText}};">无特别忌事</text>
      </view>
    </view>

    <!-- 与八字的关系 -->
    <view class="card mt-md" style="border-color: {{currentTheme.border}};" wx:if="{{huangli.clash && huangli.clash.descriptions}}">
      <view class="card-title" style="color: {{currentTheme.primary}};">与您八字的关系</view>
      <view wx:for="{{huangli.clash.descriptions}}" wx:key="*this">
        <text class="clash-desc" style="color: {{currentTheme.subText}}; border-color: {{currentTheme.divider}};">{{item}}</text>
      </view>
    </view>

    <!-- 五行运势 -->
    <view class="card mt-md" style="border-color: {{currentTheme.border}};" wx:if="{{huangli.wuxingFortune}}">
      <view class="card-title" style="color: {{currentTheme.primary}};">五行运势</view>
      <text class="wx-desc" style="color: {{currentTheme.bodyText}};">今日五行：{{huangli.wuxingFortune.wuxing || ''}}</text>
      <text class="wx-tip mt-sm" style="color: {{currentTheme.accent}};">{{huangli.wuxingFortune.description || ''}}</text>
    </view>

    <!-- 其他信息 -->
    <view class="card mt-md" style="border-color: {{currentTheme.border}};">
      <view class="info-row" style="border-color: {{currentTheme.border}};">
        <text class="info-label" style="color: {{currentTheme.subText}};">冲煞</text>
        <text class="info-val" style="color: {{currentTheme.bodyText}};">{{huangli.chongsha || '-'}}</text>
      </view>
      <view class="info-row" style="border-color: {{currentTheme.border}};">
        <text class="info-label" style="color: {{currentTheme.subText}};">吉神方位</text>
        <text class="info-val" style="color: {{currentTheme.bodyText}};">{{huangli.luckyDirection ? huangli.luckyDirection.join('、') : '-'}}</text>
      </view>
      <view class="info-row" style="border-color: {{currentTheme.border}};">
        <text class="info-label" style="color: {{currentTheme.subText}};">胎神</text>
        <text class="info-val" style="color: {{currentTheme.bodyText}};">{{huangli.taishen || '-'}}</text>
      </view>
    </view>

    <view class="disclaimer mt-md">
      <text style="color: {{currentTheme.mutedText}};">命理分析仅供参考，人生在于自身的努力和选择。</text>
    </view>
  </block>
</view>
