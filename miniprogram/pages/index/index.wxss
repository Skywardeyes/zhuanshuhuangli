page { background: #FFF8DC; }
.container { padding: 30rpx; }

/* 欢迎页 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}
.welcome-icon { font-size: 120rpx; }
.welcome-sub { font-size: 28rpx; color: #999; text-align: center; line-height: 1.6; }
.welcome-desc { text-align: center; }
.welcome-desc text { display: block; font-size: 22rpx; color: #ccc; line-height: 1.8; }

.btn-primary {
  background: linear-gradient(135deg, #C41E1E, #8B0000);
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.title-primary {
  font-family: 'Songti SC', serif;
  font-size: 48rpx;
  font-weight: bold;
  color: #C41E1E;
}

/* 今日运势 */
.greeting {
  font-family: 'Songti SC', serif;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.today-card {
  background: linear-gradient(135deg, #FFFBF5, #FFF5F0);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid #F0E6D3;
}

.today-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.td-lunar {
  font-family: 'Songti SC', serif;
  font-size: 44rpx;
  font-weight: bold;
  color: #C41E1E;
  display: block;
}
.td-solar {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

/* 宜忌摘要 */
.today-yi-ji {
  display: flex;
  gap: 20rpx;
}
.yij-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.yij-divider {
  width: 2rpx;
  background: #F0E6D3;
}
.yij-label {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}
.yi-label { color: #2E7D32; }
.ji-label { color: #C41E1E; }
.yij-item {
  font-size: 26rpx;
  color: #666;
}

/* 冲合 */
.today-clash {
  background: #FFF8E1;
  border-radius: 10rpx;
  padding: 16rpx;
}
.today-clash text {
  display: block;
  font-size: 24rpx;
  color: #B8860B;
  line-height: 1.8;
}

.loading-wrap { text-align: center; padding: 60rpx 0; }
.loading-text { color: #999; font-size: 26rpx; }

/* 快捷入口 */
.quick-actions {
  display: flex;
  gap: 30rpx;
}
.qa-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.qa-icon { font-size: 48rpx; }
.qa-text { font-size: 28rpx; color: #333; font-weight: bold; }

/* 调试面板 */
.debug-area {
  text-align: center;
  padding: 20rpx;
  margin-top: 40rpx;
}
.debug-toggle {
  color: #ccc;
  font-size: 24rpx;
}
.debug-panel {
  background: #f9f9f9;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 10rpx;
}
.debug-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}
.debug-label {
  color: #999;
  font-size: 24rpx;
}
.debug-val {
  font-size: 24rpx;
  color: #333;
}
.debug-val.green { color: #2E7D32; }
.debug-val.red { color: #C41E1E; }
.debug-retry {
  margin-top: 16rpx;
  background: #eee;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx;
  border-radius: 8rpx;
  text-align: center;
}
