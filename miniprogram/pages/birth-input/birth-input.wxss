page {
  background: #FFF8DC;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

.container {
  padding: 40rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 60rpx;
  gap: 16rpx;
}
.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E8DDD0;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C41E1E, #DAA520);
  border-radius: 4rpx;
  transition: width 0.3s;
}
.step-text {
  font-size: 24rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
}

/* 标题 */
.title-primary {
  font-family: 'Songti SC', serif;
  font-size: 44rpx;
  font-weight: bold;
  color: #C41E1E;
  text-align: center;
  margin-bottom: 8rpx;
}
.sub-title {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* Step 1: 性别 */
.gender-row {
  display: flex;
  gap: 40rpx;
  justify-content: center;
}
.gender-card {
  width: 200rpx;
  height: 260rpx;
  border: 3rpx solid #E0D5C0;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 36rpx;
  background: #fff;
  transition: all 0.2s;
}
.gender-card.selected {
  border-color: #C41E1E;
  background: #FFF0F0;
}
.gender-symbol {
  font-size: 64rpx;
  color: #C41E1E;
}

/* Step 2: 日历切换 */
.calendar-toggle {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 30rpx;
}
.calendar-toggle text { color: #999; }
.calendar-toggle .active { color: #C41E1E; font-weight: bold; }
.toggle-box {
  width: 80rpx;
  height: 40rpx;
  background: #E8DDD0;
  border-radius: 20rpx;
  position: relative;
}
.toggle-dot {
  width: 32rpx;
  height: 32rpx;
  background: #C41E1E;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 6rpx;
  transition: all 0.2s;
}
.toggle-dot.right {
  left: 42rpx;
}

/* 日期选择器 */
.date-picker {
  width: 500rpx;
  padding: 28rpx 40rpx;
  background: #fff;
  border: 2rpx solid #E0D5C0;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
}
.placeholder { color: #ccc; }
.arrow { color: #999; font-size: 24rpx; }

/* Step 3: 时辰网格 */
.shichen-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  width: 100%;
}
.shichen-item {
  width: 45%;
  padding: 20rpx;
  background: #fff;
  border: 2rpx solid #E0D5C0;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.15s;
}
.shichen-item.selected {
  border-color: #C41E1E;
  background: #FFF0F0;
}
.shi-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.shi-time {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.shichen-item.selected .shi-name { color: #C41E1E; }
.skip-row { text-align: center; }
.skip-text { color: #999; font-size: 28rpx; }

/* 错误 */
.error-msg {
  color: #C41E1E;
  font-size: 26rpx;
  margin-top: 20rpx;
  text-align: center;
}

/* 按钮 */
.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 60rpx;
  width: 100%;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #C41E1E, #8B0000);
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  flex: 1;
  max-width: 360rpx;
}
.btn-primary[disabled] {
  opacity: 0.6;
}
.btn-outline {
  border: 2rpx solid #C41E1E;
  color: #C41E1E;
  border-radius: 44rpx;
  padding: 24rpx 50rpx;
  font-size: 28rpx;
  background: transparent;
}
