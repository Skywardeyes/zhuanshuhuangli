<view class="container" style="background: {{currentTheme.bg}}; min-height: 100vh;">
  <!-- 未排盘提示 -->
  <view wx:if="{{noBazi}}" class="empty-state mt-lg">
    <text style="color: {{currentTheme.subText}};">请先完成八字排盘</text>
    <button class="btn-primary mt-lg" style="background: {{currentTheme.gradient}}; color: {{currentTheme.btnText}};" bindtap="goToBazi">前往排盘</button>
  </view>

  <block wx:if="{{!noBazi}}">
    <!-- 八字切换器 -->
    <view class="page-header">
      <bazi-switcher visible="{{!noBazi}}" currentTheme="{{currentTheme}}" bind:bazichange="onBaziChange" />
    </view>

    <!-- 月份切换 -->
    <view class="month-header">
      <view class="month-arrow" style="color: {{currentTheme.primary}};" bindtap="prevMonth">◀</view>
      <view class="month-title">
        <text style="color: {{currentTheme.bodyText}};">{{year}}年 {{month}}月</text>
      </view>
      <view class="month-arrow" style="color: {{currentTheme.primary}};" bindtap="nextMonth">▶</view>
    </view>

    <!-- 日历 -->
    <view class="card" style="border-color: {{currentTheme.border}};">
      <calendar-grid
        year="{{year}}"
        month="{{month}}"
        monthData="{{monthData}}"
        today="{{today}}"
        currentTheme="{{currentTheme}}"
        bind:daytap="onDayTap"
      />
    </view>

    <!-- 加载 -->
    <view wx:if="{{loading && monthData.length === 0}}" class="loading-wrap">
      <text class="loading-text" style="color: {{currentTheme.subText}};">加载中...</text>
    </view>

    <!-- 今日黄历卡片 -->
    <view class="mt-md" style="width:100%" wx:if="{{todayHuangli}}">
      <view class="section-title" style="color: {{currentTheme.primary}};">今日黄历</view>
      <huangli-card huangli="{{todayHuangli}}" showDetail="{{true}}" currentTheme="{{currentTheme}}" bind:tap="onTodayDetail" />
    </view>
  </block>
</view>
