<view class="hl-card {{compact ? 'compact' : ''}}">
  <!-- 头部：日期 + 运势 -->
  <view class="hl-header">
    <view class="hl-date">
      <text class="hl-lunar" style="color: {{currentTheme.primary}};">{{huangli.lunarMonthName || ''}}{{huangli.lunarDayName || ''}}</text>
      <text class="hl-solar" style="color: {{currentTheme.subText}};">{{huangli.date || ''}}</text>
    </view>
    <fortune-indicator score="{{huangli.fortuneScore}}" level="{{huangli.fortuneLevel}}" size="small" />
  </view>

  <!-- 干支信息 -->
  <view class="hl-ganzhi" wx:if="{{!compact}}">
    <text style="color: {{currentTheme.subText}};">日柱：{{huangli.dayStem}}{{huangli.dayBranch}}</text>
  </view>

  <!-- 宜 -->
  <view class="hl-section" wx:if="{{huangli.yi && huangli.yi.length > 0}}">
    <text class="hl-label yi-label" style="color: {{currentTheme.yiColor}};">宜</text>
    <view class="hl-tags">
      <text class="tag tag-green" style="background: {{currentTheme.tagBg}}; color: {{currentTheme.yiColor}};" wx:for="{{huangli.yi}}" wx:key="*this" wx:if="{{index < 6}}">{{item}}</text>
    </view>
  </view>

  <!-- 忌 -->
  <view class="hl-section" wx:if="{{huangli.ji && huangli.ji.length > 0}}">
    <text class="hl-label ji-label" style="color: {{currentTheme.jiColor}};">忌</text>
    <view class="hl-tags">
      <text class="tag tag-red" style="background: {{currentTheme.highlight}}; color: {{currentTheme.jiColor}};" wx:for="{{huangli.ji}}" wx:key="*this" wx:if="{{index < 6}}">{{item}}</text>
    </view>
  </view>

  <!-- 冲合提示 -->
  <view class="hl-clash" style="background: {{currentTheme.clashBg}};" wx:if="{{huangli.clash && huangli.clash.descriptions && huangli.clash.descriptions.length > 0 && !compact}}">
    <text wx:for="{{huangli.clash.descriptions}}" wx:key="*this" class="clash-text" style="color: {{currentTheme.clashText}};">{{item}}</text>
  </view>

  <!-- 详情入口 -->
  <view class="hl-detail-link" wx:if="{{showDetail && !compact}}" bindtap="onDetail">
    <text style="color: {{currentTheme.primary}};">查看详情 →</text>
  </view>
</view>
