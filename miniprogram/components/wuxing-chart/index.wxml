<view class="wx-chart" style="background: {{currentTheme.cardBg}}; border-color: {{currentTheme.border}};">
  <view class="wx-title" style="color: {{currentTheme.primary}};">五行力量分布</view>
  <view class="wx-bars">
    <view class="wx-bar-row" wx:for="{{wuxingList}}" wx:key="*this">
      <text class="wx-label" style="color: {{currentTheme.bodyText}};">{{item}}</text>
      <view class="wx-bar-bg" style="background: {{currentTheme.border}};">
        <view
          class="wx-bar-fill"
          style="width: {{(wuxingCount[item] || 0) / maxCount * 100}}%; background: {{colors[item]}};"
        ></view>
      </view>
      <text class="wx-val" style="color: {{currentTheme.subText}};">{{wuxingCount[item] || 0}}</text>
    </view>
  </view>

  <!-- 喜用神 / 忌神 -->
  <view class="wx-gods mt-md" style="border-color: {{currentTheme.divider}};" wx:if="{{xiyong.xiyong && xiyong.xiyong.length > 0}}">
    <view class="god-row">
      <text class="god-label tag-green" style="background: {{currentTheme.tagBg}}; color: {{currentTheme.yiColor}};">喜用神</text>
      <text class="god-items" style="color: {{currentTheme.bodyText}};" wx:for="{{xiyong.xiyong}}" wx:key="*this">{{item}} </text>
    </view>
    <view class="god-row">
      <text class="god-label tag-red" style="background: {{currentTheme.highlight}}; color: {{currentTheme.jiColor}};">忌神</text>
      <text class="god-items" style="color: {{currentTheme.bodyText}};" wx:for="{{xiyong.jishen}}" wx:key="*this">{{item}} </text>
    </view>
  </view>
</view>
