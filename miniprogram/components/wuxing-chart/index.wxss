.wx-chart {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.wx-title {
  font-family: 'Songti SC', serif;
  font-size: 32rpx;
  font-weight: bold;
  color: #C41E1E;
  margin-bottom: 24rpx;
}

.wx-bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.wx-label {
  width: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.wx-bar-bg {
  flex: 1;
  height: 24rpx;
  background: #F5F0EB;
  border-radius: 12rpx;
  overflow: hidden;
}

.wx-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s;
}

.wx-val {
  width: 50rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

/* 喜用神 */
.wx-gods {
  border-top: 1rpx solid #E8DDD0;
  padding-top: 20rpx;
}
.god-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 12rpx;
}
.god-label {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.god-items {
  font-size: 28rpx;
  color: #333;
}
