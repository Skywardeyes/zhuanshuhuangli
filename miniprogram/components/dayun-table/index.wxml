<view class="dayun-wrap" style="background: {{currentTheme.cardBg}}; border-color: {{currentTheme.border}};">
  <view class="dayun-header">
    <text class="dayun-title" style="color: {{currentTheme.primary}};">大运排盘</text>
    <text class="dayun-dir" style="color: {{currentTheme.subText}};">{{dayun.direction}} · {{dayun.qiyunAge}}岁起运</text>
  </view>

  <scroll-view scroll-x class="dayun-scroll">
    <view class="dayun-list">
      <!-- 起运前小运 -->
      <view class="dayun-item small" style="border-color: {{currentTheme.border}};">
        <text class="du-age" style="color: {{currentTheme.subText}};">0-{{dayun.qiyunAge - 1}}岁</text>
        <text class="du-ganzhi" style="color: {{currentTheme.subText}};">小运</text>
      </view>
      <!-- 各步大运 -->
      <view
        wx:for="{{dayun.dayunList}}"
        wx:key="order"
        class="dayun-item {{item.ageStart <= currentAge && item.ageEnd >= currentAge ? 'current' : ''}}"
        style="{{item.ageStart <= currentAge && item.ageEnd >= currentAge ? 'background: ' + currentTheme.gradient + '; border-color: ' + currentTheme.primary : 'border-color: ' + currentTheme.border + '; background: ' + currentTheme.cardBg}}"
      >
        <text class="du-age" style="color: {{item.ageStart <= currentAge && item.ageEnd >= currentAge ? '#FFD700' : currentTheme.subText}};">{{item.ageStart}}-{{item.ageEnd}}岁</text>
        <text class="du-ganzhi" style="color: {{item.ageStart <= currentAge && item.ageEnd >= currentAge ? '#FFD700' : currentTheme.bodyText}};">{{item.stem}}{{item.branch}}</text>
      </view>
    </view>
  </scroll-view>
</view>
