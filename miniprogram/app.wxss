/** 专属黄历 - 全局样式 **/

/* 颜色变量 (通过类名使用) */
/* 主色: #C41E1E 中国红, 金色: #DAA520, 底色: #FFF8DC */

page {
  background: #FFF8DC;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #333333;
  font-size: 28rpx;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding: 0 30rpx;
  min-height: 100vh;
}

button {
  background: initial;
  border: none;
  padding: 0;
  line-height: inherit;
  font-size: inherit;
}

button:focus { outline: 0; }
button::after { border: none; }

/* ── 通用卡片 ── */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F0E6D3;
}

.card-red-border {
  border: 2rpx solid #C41E1E;
}

/* ── 标题 ── */
.title-primary {
  font-family: 'Songti SC', 'SimSun', 'STSong', serif;
  font-size: 40rpx;
  font-weight: bold;
  color: #C41E1E;
  text-align: center;
}

.title-secondary {
  font-family: 'Songti SC', 'SimSun', 'STSong', serif;
  font-size: 32rpx;
  font-weight: bold;
  color: #8B0000;
}

.title-gold {
  font-family: 'Songti SC', 'SimSun', 'STSong', serif;
  font-size: 36rpx;
  color: #B8860B;
}

/* ── 按钮 ── */
.btn-primary {
  background: linear-gradient(135deg, #C41E1E, #8B0000);
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-gold {
  background: linear-gradient(135deg, #DAA520, #B8860B);
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-outline {
  border: 2rpx solid #C41E1E;
  color: #C41E1E;
  border-radius: 44rpx;
  padding: 20rpx 50rpx;
  font-size: 28rpx;
  text-align: center;
  background: transparent;
}

/* ── 文本 ── */
.text-center { text-align: center; }
.text-red { color: #C41E1E; }
.text-gold { color: #B8860B; }
.text-gray { color: #999999; }
.text-sub { color: #666666; font-size: 26rpx; }

/* ── 分割线 ── */
.divider {
  width: 100%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #E0D5C0, transparent);
  margin: 24rpx 0;
}

/* ── Flex工具 ── */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}

/* ── 间距 ── */
.mt-sm { margin-top: 12rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 40rpx; }
.mb-sm { margin-bottom: 12rpx; }
.mb-md { margin-bottom: 24rpx; }
.p-sm { padding: 12rpx; }
.p-md { padding: 24rpx; }

/* ── 标签/徽章 ── */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-red {
  background: #FDE8E8;
  color: #C41E1E;
}

.tag-gold {
  background: #FDF3D1;
  color: #B8860B;
}

.tag-green {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-gray {
  background: #F5F5F5;
  color: #999999;
}

/* ── Loading ── */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 26rpx;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
